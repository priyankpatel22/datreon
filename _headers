# ============================================================
# Cloudflare Pages headers — security + caching
# Auto-applied on deploy. Ignored by the local python preview server.
# ============================================================

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://cdn.jsdelivr.net https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Content-Security-Policy (above) was validated against the live resource set:
#   script-src  -> 'self' + inline importmap/JSON-LD + GSAP/Lenis/Three.js from cdn.jsdelivr.net
#   style-src   -> 'self' + inline <style> (capability page) + Google Fonts CSS
#   font-src    -> Google Fonts (fonts.gstatic.com)
#   img-src     -> 'self' + data: URIs
#   connect-src -> 'self' + cdn.jsdelivr.net (Three.js ES module) + cloudflareinsights.com (analytics beacon POST)
#   script-src  also allows static.cloudflareinsights.com (Cloudflare's auto-injected beacon.min.js)
# If you later add another analytics/CDN/script origin, append it to the matching directive
# or it will be blocked. 'unsafe-inline' in script-src is required by the <script type="importmap">.
